# Environment Variables for OHMKenya API
# Copy this file to .env and fill in the values

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ohmkenya

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# M-Pesa API
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_ENVIRONMENT=sandbox
# Callback URL for STK Push (use ngrok for local testing)
MPESA_CALLBACK_URL=https://your-ngrok-url.ngrok.io/api/mpesa

# Manufacturer API Keys
HEXING_API_KEY=
HEXING_API_URL=
STRON_API_KEY=
STRON_API_URL=
CONLOG_API_KEY=
CONLOG_API_URL=

# SMS Providers
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=
HOSTPINNACLE_API_KEY=
HOSTPINNACLE_SENDER_ID=

# Application
NODE_ENV=development
PORT=3000
